{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mypie",
  "version": "0.1.0",
  "identifier": "ground.chaotic.mypie",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mypie",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../packages/ai-bridge": "ai-bridge"
    }
  }
}
